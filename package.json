{
  "name": "create-rolldown",
  "version": "0.1.0",
  "type": "module",
  "description": "Scaffolding tool for Rolldown projects",
  "license": "MIT",
  "author": "Rolldown Team",
  "bin": {
    "create-rolldown": "index.js"
  },
  "files": [
    "index.js",
    "template-*",
    "dist"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm format && pnpm lint"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@vercel/detect-agent": "^1.0.0",
    "cross-spawn": "^7.0.3",
    "mri": "^1.2.0",
    "picocolors": "^1.0.0"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/mri": "^1.1.5",
    "@types/node": "^20.11.0",
    "execa": "^9.0.0",
    "fast-check": "^3.15.0",
    "oxfmt": "^0.24.0",
    "oxlint": "^0.17.0",
    "simple-git-hooks": "^2.12.1",
    "tsdown": "^0.2.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
